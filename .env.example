# Все значения ниже — фиктивные примеры для локальной разработки.
# Реальные секреты живут только в окружении развёртывания (12-factor).

# Окружение: dev | test | prod
APP_ENV=dev
LOG_LEVEL=INFO

# PostgreSQL — разделение ролей (схема §3.1). Рантайм подключается как
# app_user (RLS применяется), миграции — как app_migrator (владелец),
# кросс-тенантные операции — как app_maintenance, а удаление старых записей
# журнала аудита — как app_retention (единственная роль с DELETE на audit_log).
# Роли создаёт init-скрипт docker/postgres-init/01-roles.sql (dev) или
# provisioning-документ (prod).
DATABASE_URL=postgresql+asyncpg://app_user:app_user@localhost:5432/backend_core
DATABASE_MIGRATOR_URL=postgresql+asyncpg://app_migrator:app_migrator@localhost:5432/backend_core
DATABASE_MAINTENANCE_URL=postgresql+asyncpg://app_maintenance:app_maintenance@localhost:5432/backend_core
DATABASE_RETENTION_URL=postgresql+asyncpg://app_retention:app_retention@localhost:5432/backend_core

# Redis (кеш, rate limiting, очереди arq)
REDIS_URL=redis://localhost:6379/0

# --- auth (дефолты шаблона; переопределяются per-project) ---
# Секрет подписи JWT (HS256). В проде — обязательно из окружения.
JWT_SECRET=dev-insecure-change-me
# Ключи шифрования секретов тенантов/2FA (Fernet, base64). Пусто в dev = dev-ключ.
# Несколько через запятую — ротация MultiFernet.
SECRET_ENCRYPTION_KEYS=

# Sentry: пусто = выключен. PII-scrubbing включён всегда (см. app/observability.py)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# CORS: белый список origins через запятую; пусто = кросс-доменные запросы запрещены
CORS_ORIGINS=

# Включённые бизнес-модули через запятую (ядро включено всегда); commerce появится в Фазе 6
ENABLED_MODULES=

# --- billing (платёжные провайдеры) ---
# Включённые провайдеры через запятую: payme,click (UZS) и/или stripe (зарубежные
# клиенты). Провайдер, включённый без кредов, падает на старте (build_payment_providers).
ENABLED_PAYMENT_PROVIDERS=
# Заброшенный checkout протухает через N секунд (джоба воркера).
PAYMENT_CHECKOUT_TTL_SECONDS=3600
# Payme (Paycom) Merchant API.
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
# Click Merchant (SHOP-API).
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
# Stripe (зарубежные клиенты): секретный API-ключ + секрет подписи вебхука.
# Суммы 1:1 с minor units ledger (у Stripe та же конвенция минимальной единицы).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Куда Stripe вернёт покупателя (оба обязательны). return_url из create_payment,
# если задан, переопределяет success; cancel берётся из конфига.
STRIPE_SUCCESS_URL=https://example.com/checkout/success
STRIPE_CANCEL_URL=https://example.com/checkout/cancel

# --- files (объектное хранилище core/files) ---
# Бэкенд: filesystem (dev/test, без внешнего сервиса) | s3 (прод, S3-совместимый).
# s3 без кредов падает на старте (build_storage), как платёжный провайдер.
FILES_STORAGE_BACKEND=filesystem
# Локальный корень для filesystem-бэкенда; пусто = временный каталог ОС.
FILES_FILESYSTEM_ROOT=
# Потолок размера загрузки (байты); тип проверяется по magic bytes (allowlist ниже).
FILES_MAX_UPLOAD_BYTES=10485760
FILES_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif
# Потолок большей стороны превью (px); attach генерит уменьшенный вариант без метаданных.
FILES_THUMBNAIL_MAX_EDGE=256
# S3-совместимый бэкенд (заполнять при FILES_STORAGE_BACKEND=s3):
FILES_S3_ENDPOINT_URL=
FILES_S3_BUCKET=backend-core-files
FILES_S3_REGION=us-east-1
FILES_S3_ACCESS_KEY=
FILES_S3_SECRET_KEY=
