# Все значения ниже — фиктивные примеры для локальной разработки.
# Реальные секреты живут только в окружении развёртывания (12-factor).

# Окружение: dev | test | prod
APP_ENV=dev
LOG_LEVEL=INFO

# PostgreSQL (эти же креды поднимает docker-compose для dev)
DATABASE_URL=postgresql+asyncpg://backend:backend@localhost:5432/backend_core

# Redis (кеш, rate limiting, очереди arq)
REDIS_URL=redis://localhost:6379/0

# Sentry: пусто = выключен. PII-scrubbing включён всегда (см. app/observability.py)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# CORS: белый список origins через запятую; пусто = кросс-доменные запросы запрещены
CORS_ORIGINS=

# Включённые бизнес-модули через запятую (ядро включено всегда); commerce появится в Фазе 6
ENABLED_MODULES=
